msgstr "अगले {durationOfStrongWind} घंटों के लिए आम तौर पर तेज हवा"

#: src/features/weather/ui/weather-alert.tsx:300
msgid "Generally strong wind for the next 24 hours"
msgstr "अगले 24 घंटों के लिए आम तौर पर तेज हवा"

#: src/features/weather/ui/weather-alert.tsx:303
msgid "Generally strong wind for the next hour"
msgstr "अगले घंटे के लिए आम तौर पर तेज हवा"

#: src/features/weather/ui/weather-alert.tsx:286
msgid "Generally strong wind starting in {timeUntilStrongWind} hours"
msgstr "{timeUntilStrongWind} घंटों में शुरू होने वाली आम तौर पर तेज हवा"

#: src/features/weather/ui/weather-alert.tsx:284
msgid "Generally strong wind starting in 1 hour"
msgstr "आम तौर पर तेज हवा एक घंटे में शुरू होगी"

