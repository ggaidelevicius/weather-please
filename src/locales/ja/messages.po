#~ msgid "Email (optional)"
#~ msgstr "メール（任意）"

#: src/components/settings/index.tsx:109
#~ msgid "Error"
#~ msgstr "エラー"

#: src/pages/feedback/index.tsx:475
#~ msgid "Error submitting feedback. Try again later."
