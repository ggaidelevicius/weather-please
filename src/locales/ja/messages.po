msgid "thunderstorm"
msgstr "雷雨"

#: src/features/weather/ui/tile.tsx:109
msgid "thunderstorm with heavy hail"
msgstr "ひどいひょうを伴う雷雨"

#: src/features/weather/ui/tile.tsx:108
msgid "thunderstorm with slight hail"
msgstr "小規模なひょうを伴う雷雨"

#: src/features/weather/ui/tile.tsx:117
msgid "Thursday"
msgstr "木曜日"

