#: src/features/seasonal-events/events/total-lunar-eclipse.tsx:71
msgid "Why it turns red"
msgstr "Kodėl jis parausta"

#: src/features/seasonal-events/events/quadrantids.tsx:110
msgid "Why the peak is brief"
msgstr "Kodėl pikas trumpas"

