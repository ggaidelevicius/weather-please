#: src/features/weather/ui/tile.tsx:384
msgid "The maximum temperature will be {0} degrees celsius."
msgstr "Максимальная температура составит {0} градусов по Цельсию."

#. placeholder {0}: Math.round((max * 9) / 5 + 32)
#: src/features/weather/ui/tile.tsx:390
msgid "The maximum temperature will be {0} degrees fahrenheit."
msgstr "Максимальная температура составит {0} градусов по Фаренгейту."

#. placeholder {0}: Math.round(uv)
#: src/features/weather/ui/tile.tsx:446
msgid "The maximum UV index will be {0}."
msgstr "Максимальный индекс УФ будет {0}."

