		"babel-plugin-react-compiler": "19.1.0-rc.2",
		"dotenv": "^17.4.2",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.9.0",
		"fs-extra": "^11.3.5",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
