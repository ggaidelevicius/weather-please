		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@11.4.0",
	"lint-staged": {
		"*.{js,jsx,mjs,cjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write",
			"bash -c 'tsc --noEmit'"
		],
		"*.{json,css,md}": "prettier --write"
	}
}
