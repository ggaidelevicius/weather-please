		"babel-plugin-macros": "^3.1.0",
		"canvas-confetti": "^1.9.4",
		"clsx": "^2.1.1",
		"framer-motion": "^12.40.0",
		"next": "16.2.6",
		"postcss": "^8.5.15",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"tailwindcss": "^4.3.0",
